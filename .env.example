# Palma Coin — Environment Variables
# Copy this file to .env and fill in the values

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (local or Railway)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/palma_coin

# ─── Auth ───────────────────────────────────────────────────────────────────
# JWT secret — change this in production!
JWT_SECRET=palma-coin-dev-secret-change-in-production

# ─── Server ─────────────────────────────────────────────────────────────────
# Railway sets PORT automatically; locally defaults to 3001
PORT=3001

# ─── Environment ───────────────────────────────────────────────────────────
NODE_ENV=development